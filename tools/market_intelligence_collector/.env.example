# MIC environment variables (copy to .env and fill in)

# --- Model providers (OpenAI-compatible) ---
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
OPENCLAW_GATEWAY_TOKEN=
# Vision (text+image) model on the OpenClaw side, sent as the x-openclaw-model
# header for image transcription calls only (scanned PDFs / page screenshots).
# Example: custom-api-siliconflow-cn/Pro/moonshotai/Kimi-K2.6
OPENCLAW_VISION_MODEL=

# --- Search providers ---
# One key serves all serpapi_* providers (baidu/google/bing engines); leave
# empty to use the built-in mock provider. (The native Bing Search API was
# retired by Microsoft in 2025, so there is no separate Bing key.)
SERPAPI_API_KEY=
# Tavily search API (https://tavily.com, free tier 1000 calls/month).
# Used by the "tavily" provider (default rescue fallback).
TAVILY_API_KEY=
# Self-hosted SearXNG instance (see searxng/docker-compose.yml).
SEARXNG_BASE_URL=http://localhost:8888

# --- Storage ---
# Default is local SQLite. For PostgreSQL use e.g.
#   postgresql+psycopg://user:pass@localhost:5432/mic
MIC_DATABASE_URL=sqlite:///mic.db

# --- Runtime ---
# If true (default), missing API keys cause adapters to fall back to a deterministic
# mock so the pipeline can be demoed end-to-end without external services.
MIC_ALLOW_MOCK=true
