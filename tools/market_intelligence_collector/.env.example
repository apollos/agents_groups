# MIC environment variables (copy to .env and fill in)

# --- Model providers (OpenAI-compatible) ---
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
OPENCLAW_GATEWAY_TOKEN=

# --- Search providers ---
# Used by the "serpapi" provider; leave empty to use the built-in mock provider.
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=

# --- Storage ---
# Default is local SQLite. For PostgreSQL use e.g.
#   postgresql+psycopg://user:pass@localhost:5432/mic
MIC_DATABASE_URL=sqlite:///mic.db

# --- Runtime ---
# If true (default), missing API keys cause adapters to fall back to a deterministic
# mock so the pipeline can be demoed end-to-end without external services.
MIC_ALLOW_MOCK=true
