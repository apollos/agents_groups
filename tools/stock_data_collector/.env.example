# Do not commit real credentials.
TUSHARE_TOKEN=
JQDATA_USERNAME=
JQDATA_PASSWORD=

# Optional: override config files and storage path.
STOCK_DATA_CONFIG_DIR=config
STOCK_DATA_SQLITE_PATH=data/stock_data.db

# Optional: browser-verified Eastmoney cookie for AKShare Eastmoney-backed APIs.
# Open https://data.eastmoney.com/zjlx/detail.html in a browser, complete verification,
# then open this API URL in the same browser and copy the Cookie request header:
# https://push2his.eastmoney.com/api/qt/stock/fflow/daykline/get?lmt=0&klt=101&secid=1.600519&fields1=f1,f2,f3,f7&fields2=f51,f52,f53,f54,f55,f56,f57,f58,f59,f60,f61,f62,f63,f64,f65&ut=b2884a393a59ad64002292a3e90d46a5
# Update this value with:
#   python tools/update_eastmoney_cookie.py --cookie '<cookie string>'
# Verify it with:
#   python -m stock_data_ingestion.cli verify eastmoney-cookie
EASTMONEY_COOKIE=
EASTMONEY_USER_AGENT=

# Provider selection. Provider ids: tushare, akshare, baostock, joinquant.
# Aliases accepted: thushare/ts, ak/tencent, bao_stock/bs, jqdata/jq.
# Recommended first-stage default: Tushare canonical, AKShare Tencent + BaoStock as supplement/validation, JQData disabled.
STOCK_DATA_PROVIDERS=tushare,akshare,baostock
STOCK_DATA_CANONICAL_PROVIDER=tushare
STOCK_DATA_DISABLED_PROVIDERS=joinquant
STOCK_DATA_ENABLE_JOINQUANT=false
STOCK_DATA_ENABLE_BAOSTOCK=true

# Examples:
# STOCK_DATA_PROVIDERS=tushare
# STOCK_DATA_PROVIDERS=tushare,akshare,baostock
# STOCK_DATA_PROVIDERS=akshare,baostock
# STOCK_DATA_DISABLED_PROVIDERS=
# STOCK_DATA_ENABLE_JOINQUANT=true

# Optional per request-type overrides:
# STOCK_DATA_PROVIDERS_SECURITY_MASTER=tushare,baostock,akshare
# STOCK_DATA_PROVIDERS_HISTORICAL_BARS=tushare,akshare,baostock
# STOCK_DATA_PROVIDERS_VALUATION_METRIC=tushare,baostock
# STOCK_DATA_PROVIDERS_ADJ_FACTOR=tushare,baostock
# STOCK_DATA_PROVIDERS_MONEY_FLOW=tushare,akshare
# STOCK_DATA_PROVIDERS_FINANCIAL_STATEMENT=tushare,baostock
# STOCK_DATA_PROVIDERS_FINANCIAL_INDICATOR=tushare,baostock
# STOCK_DATA_PROVIDERS_CORPORATE_ACTION=tushare,baostock
# STOCK_DATA_PROVIDERS_TRADE_CALENDAR=tushare,baostock
# STOCK_DATA_PROVIDERS_REALTIME_QUOTE=akshare
# STOCK_DATA_PROVIDERS_INDUSTRY_CONCEPT=akshare,baostock
