# Do not commit real credentials.
TUSHARE_TOKEN=
JQDATA_USERNAME=
JQDATA_PASSWORD=

# Optional: override config files and storage path.
STOCK_DATA_CONFIG_DIR=config
STOCK_DATA_SQLITE_PATH=data/stock_data.db

# Provider selection. These can be changed per shell or per command.
# Use provider ids: tushare, akshare, joinquant.
# Aliases accepted: thushare/ts, ak, jqdata/jq.
#
# Default recommended while JQData account is unavailable:
STOCK_DATA_PROVIDERS=tushare,akshare
STOCK_DATA_CANONICAL_PROVIDER=tushare
STOCK_DATA_DISABLED_PROVIDERS=joinquant

# Examples:
# STOCK_DATA_PROVIDERS=akshare
# STOCK_DATA_CANONICAL_PROVIDER=akshare
# STOCK_DATA_PROVIDERS=tushare
# STOCK_DATA_PROVIDERS=tushare,akshare,joinquant
# STOCK_DATA_DISABLED_PROVIDERS=
# STOCK_DATA_ENABLE_JOINQUANT=true

# Optional per request-type overrides:
# STOCK_DATA_PROVIDERS_SECURITY_MASTER=tushare,akshare
# STOCK_DATA_PROVIDERS_HISTORICAL_BARS=tushare,akshare
# STOCK_DATA_PROVIDERS_VALUATION_METRIC=tushare,akshare
# STOCK_DATA_PROVIDERS_MONEY_FLOW=tushare,akshare
# STOCK_DATA_PROVIDERS_FINANCIAL_STATEMENT=tushare,akshare
# STOCK_DATA_PROVIDERS_FINANCIAL_INDICATOR=tushare,akshare
# STOCK_DATA_PROVIDERS_CORPORATE_ACTION=tushare,akshare
# STOCK_DATA_PROVIDERS_TRADE_CALENDAR=tushare
# STOCK_DATA_PROVIDERS_REALTIME_QUOTE=akshare
# STOCK_DATA_PROVIDERS_INDUSTRY_CONCEPT=akshare
